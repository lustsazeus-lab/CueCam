<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#405A7BA9" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#99DCE7FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2E3B4D67"
                android:endColor="#26344763" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#70BFD2F6" />
        </shape>
    </item>
</selector>
